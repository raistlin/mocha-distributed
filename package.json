    "docker",
    "mocha-parallel-tests",
    "mocha.parallel",
    "tests"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pausan/mocha-distributed.git"
  },
  "author": "Pau Sanchez",
  "license": "MIT",
  "dependencies": {
    "redis": "^6.1.0"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.7"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.6"
  }
}
